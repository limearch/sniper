#!/usr/bin/python3
import getmac
import nmap
import socket
import time
import json
import csv
from requests import get
from rich import box
from rich.live import Live
from rich.table import Table
from rich.console import Console
from N4Tools.Design import ThreadAnimation, AnimationTools, Animation
from N4Tools.terminal import terminal
import argparse

# Initialize terminal, color, and animation objects
console = Console()
AN = Animation()

class NetworkInfo:
    def __init__(self):
        """Initialize and scan the network."""
        self.Nmap = nmap.PortScanner()
        self.scan_time = None  # Store the time taken for the scan
        # Determine subnet from internal IP
        self.hosts = self.get_subnet()
        # Start the scan and track time
        self.scan_network()

    def get_subnet(self):
        """Get the network subnet (e.g., 192.168.1.0/24)."""
        ip_parts = self.internal_ip.split('.')
        return '.'.join(ip_parts[:-1]) + '.0/24'

    def scan_network(self):
        """Perform a network scan and track the time taken."""
        console.print("\n[bold yellow]Scanning the network...[/bold yellow]")
        start_time = time.time()
        self.Nmap.scan(hosts=self.hosts, arguments='-sP')
        self.scan_time = time.time() - start_time
        console.print(f"\n[bold green]Scan completed in {self.scan_time:.2f} seconds.[/bold green]")

    @property
    def internal_ip(self):
        """Retrieve the internal IP address."""
        with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as s:
            s.connect(("8.8.8.8", 80))
            return s.getsockname()[0]

    @property
    def external_ip(self):
        """Fetch external IP information using ipinfo.io."""
        try:
            return get('http://ipinfo.io/json').json()
        except Exception as e:
            return {"error": str(e)}

    def show_ip_info(self):
        """Display internal and external IP information in a table."""
        table = Table(title="[bold magenta]Network IP Information[/bold magenta]", box=box.DOUBLE_EDGE, expand=True)
        table.add_column("[yellow]Option[/yellow]", justify="center", style="cyan")
        table.add_column("[yellow]Value[/yellow]", justify="center", style="green")

        # Internal IP
        table.add_row("Internal IP", f"[bold cyan]{self.internal_ip}[/bold cyan]")

        # External IP info
        external_info = self.external_ip
        for key, val in external_info.items():
            if key not in ['hostname', 'readme']:
                key = key.replace('ip', 'External IP')
                table.add_row(f"[bold cyan]{key.capitalize()}[/bold cyan]", f"[bold green]{val}[/bold green]")

        console.print(table)

    def list_wifi_users(self):
        """Display the list of connected devices in a table."""
        table = Table(title="[bold magenta]Connected Wi-Fi Devices[/bold magenta]", box=box.DOUBLE_EDGE, expand=True)
        table.add_column("[cyan]Device[/cyan]", justify="center")
        table.add_column("[green]IP Address[/green]", justify="center")
        table.add_column("[green]MAC Address[/green]", justify="center")

        devices = self.get_connected_devices()

        with Live(table, refresh_per_second=1):
            for device in devices:
                table.add_row(
                    f"[bold cyan]{device['device_name']}[/bold cyan]", 
                    f"[bold green]{device['ip']}[/bold green]", 
                    f"[bold yellow]{device['mac'] if device['mac'] else '[red]Unknown[/red]'}[/bold yellow]"
                )
        
        console.print(f"[bold yellow]Total devices found: {len(devices)}[/bold yellow]")

    def get_connected_devices(self):
        """Get list of connected devices."""
        devices = []
        for ip in self.Nmap.all_hosts():
            device_name = socket.getfqdn(ip)
            device_name = '[red]Unknown[/red]' if device_name == ip else device_name
            mac = getmac.get_mac_address(ip=ip)
            devices.append({
                "device_name": device_name,
                "ip": ip,
                "mac": mac if mac else 'Unknown'
            })
        return devices

    def save_to_file(self, filename, format='json'):
        """Save scan results to a file in JSON or CSV format."""
        devices = self.get_connected_devices()
        if format == 'json':
            with open(filename, 'w') as f:
                json.dump(devices, f, indent=4)
            console.print(f"[bold green]Results saved to {filename} in JSON format.[/bold green]")
        elif format == 'csv':
            with open(filename, 'w', newline='') as f:
                writer = csv.DictWriter(f, fieldnames=["device_name", "ip", "mac"])
                writer.writeheader()
                writer.writerows(devices)
            console.print(f"[bold green]Results saved to {filename} in CSV format.[/bold green]")

# Define loading animation
text_anim = AnimationTools.set_text_anim('Network scan is in progress...')
kwargs = {'text': text_anim}

@ThreadAnimation(Animation=AN.Loading, kwargs=kwargs, timer=.15)
def perform_scan(Thread):
    """Perform the network scan with loading animation."""
    return NetworkInfo()

def parse_args():
    """Parse command-line arguments."""
    parser = argparse.ArgumentParser(description="Network scanning tool.")
    parser.add_argument('-o', '--output', type=str, help="Save scan results to a file (specify the filename)")
    parser.add_argument('-x', '--export', choices=['json', 'csv'], default='json', help="Specify export format (json or csv)")
    return parser.parse_args()

if __name__ == '__main__':
    # Parse arguments
    args = parse_args()

    # Run the network scan
    network_info = perform_scan()

    # Display IP information
    network_info.show_ip_info()

    # Display connected Wi-Fi users
    network_info.list_wifi_users()

    # Save results if output is specified
    if args.output:
        network_info.save_to_file(args.output, args.export)
