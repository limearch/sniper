# Function to create virtual environment
def create_venv():
    subprocess.run(['python', '-m', 'venv', 'venv'])
    print(f"{color.LWIHTE}[{color.LGREEN}CREATED ✓{color.LWIHTE}]: Virtual environment created")

# Function to activate virtual environment
def activate_venv():
    activate_script = './venv/bin/activate' if os.name != 'nt' else '.\\venv\\Scripts\\activate'
    os.system(activate_script)
    print(f"{color.LWIHTE}[{color.LGREEN}ACTIVATED ✓{color.LWIHTE}]: Virtual environment activated")

# Function to install a package
def install_package(package_name):
    subprocess.run(['pip', 'install', package_name])
    print(f"{color.LWIHTE}[{color.LGREEN}INSTALLED ✓{color.LWIHTE}]: {package_name}")

# Function to run the main process
def main(project_dir, url):
    template_dir = os.path.join(project_dir, 'templates')
    static_dir = os.path.join(project_dir, 'static')
    flask_main_file = os.path.join(project_dir, "__main__.py")
    index_html = os.path.join(template_dir, 'index.html')

    if not validators.url(url):
        print(f"Invalid URL: {color.LRED}{url}{color.LWIHTE}")
        return

    create_project_files(project_dir, template_dir, static_dir, flask_main_file)
    extract_and_download_resources(url, template_dir, static_dir)
    modify_html_paths(index_html, "../static")

# Initialize argparse and add commands
parser = argparse.ArgumentParser(description="Web project automation tool with Flask support.")
parser.add_argument('-f', '--flask', action='store_true', help="Create a new Flask project.")
parser.add_argument('-p', '--project', type=str, help="Set the project directory name.", required=False)
parser.add_argument('-u', '--url', type=str, help="Set the URL to scrape resources.", required=False)
parser.add_argument('-v', '--venv', action='store_true', help="Create a virtual environment.")
parser.add_argument('-i', '--install', type=str, help="Install a Python package.")
parser.add_argument('-m', '--minify', action='store_true', help="Minify static assets.")
parser.add_argument('--run', action='store_true', help="Run the Flask project.")
# parser.add_argument('-h', '--help', action='help', help="Show this help message.")

# Parse arguments
args = parser.parse_args()

# Check if URL is provided when --flask is used
if args.flask:
    if not args.project or not args.url:
        print(f"{color.LRED}Error: --project and --url are required with --flask{color.LWIHTE}")
    elif not validators.url(args.url):
        print(f"{color.LRED}Invalid URL: {args.url}{color.LWIHTE}")
    else:
        main(args.project, args.url)
elif args.venv:
    create_venv()
elif args.install:
    install_package(args.install)
elif args.minify:
    minify_assets('static')
elif args.run:
    if args.project:
        os.system(f"python {args.project}")
    else:
        print(f"{color.LRED}Error: --project is required with --run{color.LWIHTE}")
else:
    print(f"{color.LRED}No valid command provided. Use --help for usage information.{color.LWIHTE}")
