#!/usr/bin/python3
import getmac
import nmap
import socket
import time
import argparse
from requests import get
from rich import box
from rich.live import Live
from rich.table import Table
from rich.console import Console
import json
import csv
from os import path

# Initialize console for rich output
console = Console()

class NetworkInfo:
    def __init__(self):
        """Initialize network scanner."""
        self.nmap = nmap.PortScanner()
        self.hosts = self.get_subnet()
        self.scan_time = None

    def get_subnet(self):
        """Get the network subnet (e.g., 192.168.1.0/24)."""
        ip_parts = self.internal_ip.split('.')
        return '.'.join(ip_parts[:-1]) + '.0/24'

    def scan_network(self):
        """Perform network scan and track time."""
        console.print("[bold yellow]Scanning the network...[/bold yellow]")
        start_time = time.time()
        self.nmap.scan(hosts=self.hosts, arguments='-sP')
        self.scan_time = time.time() - start_time
        console.print(f"[bold green]Scan completed in {self.scan_time:.2f} seconds.[/bold green]")

    def scan_single_ip(self, ip):
        """Scan a specific IP address."""
        console.print(f"[bold yellow]Scanning IP {ip}...[/bold yellow]")
        self.nmap.scan(hosts=ip, arguments='-sP')

    def compare_with_previous(self, previous_file):
        """Compare current scan with previous scan results."""
        if not path.exists(previous_file):
            console.print("[bold red]Previous scan file not found.[/bold red]")
            return
        with open(previous_file, 'r') as f:
            previous_devices = json.load(f)
        current_devices = self.get_connected_devices()
        new_devices = [dev for dev in current_devices if dev not in previous_devices]
        removed_devices = [dev for dev in previous_devices if dev not in current_devices]

        if new_devices:
            console.print(f"[bold yellow]New Devices Detected: {new_devices}[/bold yellow]")
        if removed_devices:
            console.print(f"[bold yellow]Devices No Longer Connected: {removed_devices}[/bold yellow]")

    @property
    def internal_ip(self):
        """Retrieve internal IP address."""
        with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as s:
            s.connect(("8.8.8.8", 80))
            return s.getsockname()[0]

    @property
    def external_ip(self):
        """Fetch external IP information using ipinfo.io."""
        try:
            return get('http://ipinfo.io/json').json()
        except Exception as e:
            return {"error": str(e)}

    def get_ip_info(self):
        """Return IP information."""
        internal_ip = self.internal_ip
        external_ip = self.external_ip
        return {"internal_ip": internal_ip, **external_ip}

    def get_connected_devices(self):
        """Get list of connected devices."""
        devices = []
        for ip in self.nmap.all_hosts():
            device_name = socket.getfqdn(ip)
            device_name = 'Unknown' if device_name == ip else device_name
            mac = getmac.get_mac_address(ip=ip)
            devices.append({
                "device_name": device_name,
                "ip": ip,
                "mac": mac if mac else 'Unknown'
            })
        return devices

    def save_to_file(self, filename, format="json"):
        """Save scan results to a file in JSON or CSV format."""
        devices = self.get_connected_devices()
        if format == "json":
            with open(filename, 'w') as f:
                json.dump(devices, f, indent=4)
            console.print(f"[bold green]Results saved to {filename}[/bold green]")
        elif format == "csv":
            with open(filename, 'w', newline='') as f:
                writer = csv.DictWriter(f, fieldnames=["device_name", "ip", "mac"])
                writer.writeheader()
                writer.writerows(devices)
            console.print(f"[bold green]Results saved to {filename}[/bold green]")

    def display_ip_info(self):
        """Display internal and external IP information in a table."""
        table = Table(title="[bold magenta]Network IP Information[/bold magenta]", box=box.DOUBLE_EDGE, expand=True)
        table.add_column("Option", style="cyan")
        table.add_column("Value", style="green")
        ip_info = self.get_ip_info()

        table.add_row("Internal IP", f"{ip_info['internal_ip']}")
        for key, val in ip_info.items():
            if key != 'internal_ip':
                table.add_row(key.capitalize(), val)

        console.print(table)

    def display_connected_devices(self):
        """Display the list of connected devices."""
        devices = self.get_connected_devices()
        table = Table(title="[bold magenta]Connected Wi-Fi Devices[/bold magenta]", box=box.DOUBLE_EDGE, expand=True)
        table.add_column("Device", style="cyan")
        table.add_column("IP Address", style="green")
        table.add_column("MAC Address", style="green")

        for device in devices:
            table.add_row(device['device_name'], device['ip'], device['mac'])

        console.print(table)

# Define command-line arguments
def parse_args():
    parser = argparse.ArgumentParser(description="Network scanning tool with multiple features.")
    parser.add_argument('-i', '--ip-info', action='store_true', help="Display internal and external IP information")
    parser.add_argument('-d', '--devices', action='store_true', help="List connected Wi-Fi devices")
    parser.add_argument('-f', '--full-scan', action='store_true', help="Perform a full network scan")
    parser.add_argument('-s', '--scan', type=str, help="Scan a specific IP address")
    parser.add_argument('-m', '--mac', type=str, help="Find a device by MAC address")
    parser.add_argument('-o', '--output', type=str, help="Save scan results to a file (JSON or CSV)")
    parser.add_argument('-x', '--export', type=str, choices=['json', 'csv'], help="Specify export format (json or csv)")
    parser.add_argument('-c', '--compare', type=str, help="Compare current scan with previous scan results")
    parser.add_argument('-r', '--repeat', type=int, help="Repeat scan every N seconds")
    parser.add_argument('-t', '--time', action='store_true', help="Display the time taken for the scan")
    return parser.parse_args()

# Main function to handle user input and execute features
def main():
    args = parse_args()
    network_info = NetworkInfo()

    if args.ip_info:
        network_info.display_ip_info()

    if args.devices:
        network_info.display_connected_devices()

    if args.full_scan:
        network_info.scan_network()

    if args.scan:
        network_info.scan_single_ip(args.scan)

    if args.mac:
        devices = network_info.get_connected_devices()
        found_device = next((d for d in devices if d['mac'] == args.mac), None)
        if found_device:
            console.print(f"[bold green]Device Found: {found_device['device_name']} ({found_device['ip']})[/bold green]")
        else:
            console.print(f"[bold red]Device with MAC {args.mac} not found.[/bold red]")

    if args.output:
        export_format = args.export if args.export else "json"
        network_info.save_to_file(args.output, export_format)

    if args.compare:
        network_info.compare_with_previous(args.compare)

    if args.time:
        console.print(f"[bold green]Scan completed in {network_info.scan_time:.2f} seconds.[/bold green]")

    if args.repeat:
        while True:
            network_info.scan_network()
            time.sleep(args.repeat)

if __name__ == '__main__':
    main()
