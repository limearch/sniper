#!/usr/bin/python

# sniper-scan.py (Final Version with Rich Help)
import sys
import argparse
import socket
from datetime import datetime
import threading
from queue import Queue
import re

try:
    from tqdm import tqdm
except ImportError:
    print("\n\033[91m[ERROR]\033[0m The 'tqdm' library is not installed.")
    print("Please install it to use this tool: pip install tqdm\n")
    sys.exit(1)

# --- NEW: Rich dependency for help screen ---
try:
    from rich.console import Console
    from rich.panel import Panel
    from rich.text import Text
    rich_available = True
except ImportError:
    rich_available = False

# --- Utilities (Original) ---
# Kept for the main application's colored output
class Colors:
    BLUE = '\033[94m'
    GREEN = '\033[92m'
    RED = '\033[91m'
    YELLOW = '\033[93m'
    MAGENTA = '\033[95m'
    CYAN = '\033[96m'
    ENDC = '\033[0m'
    BOLD = '\033[1m'

# --- Core Data and Functions (All original functions are unchanged) ---
COMMON_SERVICES = {
    21: "FTP", 22: "SSH", 23: "Telnet", 25: "SMTP", 53: "DNS",
    80: "HTTP", 110: "POP3", 143: "IMAP", 443: "HTTPS", 445: "SMB",
    993: "IMAPS", 995: "POP3S", 1723: "PPTP", 3306: "MySQL",
    3389: "RDP", 5900: "VNC", 8080: "HTTP-Proxy"
}
TOP_100_PORTS = [80, 23, 443, 21, 22, 25, 3389, 110, 445, 139, 143, 53, 135, 3306, 8080, 1723, 111, 995, 993, 5900, 1025, 587, 8888, 199, 1720, 465, 548, 113, 81, 6001, 10000, 514, 5060, 179, 1026, 2000, 8443, 8008, 32768, 554, 1027, 9090, 2001, 1028, 8000, 1029, 389, 49152, 1433, 636, 49153, 5357, 49154, 49155, 1030, 49156, 49157, 515, 513, 990, 5800, 5000, 7070, 6646, 3478, 32769, 5631, 32770, 5666, 32771, 646, 137, 2049, 1031, 1032, 1033, 1034, 1035, 1036, 1037, 1038, 1039, 1040, 1041, 1042, 1043, 1044, 1045, 1046, 1047, 1048, 1049, 1050]
scan_results = {}
print_lock = threading.Lock()

def scan_port(host, port, timeout, grab_banner):
    try:
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
            sock.settimeout(timeout)
            if sock.connect_ex((host, port)) == 0:
                banner = None
                if grab_banner:
                    try:
                        sock.sendall(b'HEAD / HTTP/1.0\r\n\r\n')
                        banner = sock.recv(1024).decode('utf-8', errors='ignore').strip().split('\n')[0]
                    except (socket.timeout, ConnectionResetError, BrokenPipeError):
                        pass
                service = COMMON_SERVICES.get(port, "Unknown")
                with print_lock:
                    scan_results[port] = {"status": "OPEN", "service": service, "banner": banner}
    except socket.error:
        pass

def worker(target_ip, timeout, grab_banner, pbar):
    while not port_queue.empty():
        port = port_queue.get()
        scan_port(target_ip, port, timeout, grab_banner)
        port_queue.task_done()
        pbar.update(1)

def parse_ports(ports_str, use_top_ports):
    if use_top_ports: return TOP_100_PORTS
    ports = set()
    if not ports_str: return []
    for part in ports_str.split(','):
        part = part.strip()
        if '-' in part:
            try:
                start, end = map(int, part.split('-'))
                if start <= end and 0 < start < 65536 and 0 < end < 65536: ports.update(range(start, end + 1))
            except ValueError: raise ValueError(f"Invalid port range: {part}")
        else:
            try:
                port_num = int(part)
                if 0 < port_num < 65536: ports.add(port_num)
            except ValueError: raise ValueError(f"Invalid port number: {part}")
    return sorted(list(ports))

# --- NEW: Rich Help Screen Function ---
def show_rich_help():
    """Displays the custom, rich-formatted help screen for the scanner."""
    if not rich_available:
        print("Error: 'rich' library is required for the help screen. Run: pip install rich")
        sys.exit(1)
        
    console = Console()
    title = Text("SNIPER: Port Scanner", style="bold magenta", justify="center")
    
    usage = Text.from_markup(
        "[bold]Usage:[/] [yellow]scan[/] [cyan]<HOST>[/] [green][OPTIONS][/]"
    )
    
    main_panel_text = """
[bold]Description:[/b]
  A fast and versatile TCP port scanner with service detection and
  banner grabbing capabilities. It uses multithreading for high speed.

[bold]Arguments:[/b]
  [cyan]<HOST>[/]               The target host IP address or domain name.

[bold]Port Selection (Required - Choose one):[/b]
  [green]-p, --ports[/]        Ports to scan (e.g., '22,80,443' or '1-1024').
  [green]--top-ports[/]       Scan the top 100 most common ports.

[bold]Options:[/b]
  [green]-w, --workers[/]      Number of concurrent threads (default: 100).
  [green]-t, --timeout[/]      Connection timeout in seconds (default: 1.0).
  [green]-b, --banner[/]       Attempt to grab service banners from open ports.
  [green]-o, --output <FILE>[/] Save the scan output to a file.
  [green]-h, --help[/]         Show this help message and exit.
"""

    examples_text = """
[bold]Examples:[/b]
  [#] Scan specific ports on a target
  [yellow]scan[/] [cyan]scanme.nmap.org[/] [green]-p 22,80,443[/]

  [#] Scan the top 100 ports and grab banners
  [yellow]scan[/] [cyan]example.com[/] [green]--top-ports -b[/]

  [#] Scan a full range with more workers and save the output
  [yellow]scan[/] [cyan]192.168.1.1[/] [green]-p 1-65535 -w 500 -o result.txt[/]
"""
    
    console.print(Panel(title, border_style="magenta", padding=(0, 1)))
    console.print(usage, justify="center")
    console.print(Panel(Text.from_markup(main_panel_text.strip()), title="Details", border_style="blue"))
    console.print(Panel(Text.from_markup(examples_text.strip()), title="Examples", border_style="green"))
    sys.exit(0)

def main():
    # --- MODIFIED: Argument Parser Setup ---
    parser = argparse.ArgumentParser(
        prog="scan",
        description="A fast TCP port scanner.",
        add_help=False # Disable default help
    )
    
    # --- NEW: Manual help argument ---
    parser.add_argument("-h", "--help", action="store_true", help="Show this help message.")

    # --- Original Arguments (Unchanged, but host is now optional) ---
    parser.add_argument("host", nargs='?', default=None, metavar="<HOST>", help="The target host IP or domain.")
    port_group = parser.add_mutually_exclusive_group()
    port_group.add_argument("-p", "--ports", help="Ports to scan (e.g., '22,80,443' or '1-1024').")
    port_group.add_argument("--top-ports", action="store_true", help="Scan the top 100 most common ports.")
    parser.add_argument("-w", "--workers", type=int, default=100, help="Number of concurrent threads.")
    parser.add_argument("-t", "--timeout", type=float, default=1.0, help="Connection timeout in seconds.")
    parser.add_argument("-b", "--banner", action="store_true", help="Attempt to grab service banners from open ports.")
    parser.add_argument("-o", "--output", metavar="<FILE>", help="Save the output to a file.")
    
    args = parser.parse_args()

    # --- NEW: Help screen trigger ---
    # Show help if -h is passed or if no host is provided
    if args.help or not args.host:
        show_rich_help()
    
    # Check for required port selection after checking for help
    if not args.ports and not args.top_ports:
        print(f"{Colors.RED}[ERROR]{Colors.ENDC} You must specify which ports to scan. Use -p or --top-ports.")
        print(f"For more info, run: scan --help")
        sys.exit(1)

    # --- Original execution logic (Unchanged) ---
    try:
        target_ip = socket.gethostbyname(args.host)
    except socket.gaierror:
        print(f"{Colors.RED}[ERROR]{Colors.ENDC} Could not resolve hostname: '{args.host}'")
        sys.exit(1)
    try:
        ports_to_scan = parse_ports(args.ports, args.top_ports)
        if not ports_to_scan:
            print(f"{Colors.RED}[ERROR]{Colors.ENDC} No valid ports specified.")
            sys.exit(1)
    except ValueError as e:
        print(f"{Colors.RED}[ERROR]{Colors.ENDC} {e}")
        sys.exit(1)
    print("-" * 60)
    print(f"{Colors.BLUE}[INFO]{Colors.ENDC} Scanning target: {Colors.CYAN}{args.host}{Colors.ENDC} ({target_ip})")
    print(f"{Colors.BLUE}[INFO]{Colors.ENDC} Ports to scan: {len(ports_to_scan)}")
    print(f"{Colors.BLUE}[INFO]{Colors.ENDC} Workers: {args.workers}, Timeout: {args.timeout}s")
    print("-" * 60)
    global port_queue
    port_queue = Queue()
    for port in ports_to_scan: port_queue.put(port)
    with tqdm(total=len(ports_to_scan), desc="Scanning", unit="port", ncols=80) as pbar:
        threads = []
        for _ in range(args.workers):
            thread = threading.Thread(target=worker, args=(target_ip, args.timeout, args.banner, pbar), daemon=True)
            threads.append(thread)
            thread.start()
        port_queue.join()
    output_lines = []
    output_lines.append("-" * 60)
    open_ports = sorted(scan_results.keys())
    if open_ports:
        output_lines.append(f"{Colors.GREEN}[SUCCESS]{Colors.ENDC} Scan complete. Found {len(open_ports)} open port(s):")
        header = f"  {'PORT':<10}{'SERVICE':<15}{'BANNER'}"
        output_lines.append(header)
        output_lines.append(f"  {'----':<10}{'-------':<15}{'------'}")
        for port in open_ports:
            result = scan_results[port]
            service = result['service']
            banner = (result['banner'] or "").replace('\r', '')
            line = f"  {Colors.BOLD}{port:<10}{Colors.ENDC}{service:<15}{Colors.CYAN}{banner}{Colors.ENDC}"
            output_lines.append(line)
    else:
        output_lines.append(f"{Colors.BLUE}[INFO]{Colors.ENDC} Scan complete. No open ports found.")
    for line in output_lines: print(line)
    if args.output:
        try:
            with open(args.output, "w", encoding="utf-8") as f:
                ansi_escape = re.compile(r'\x1B(?:[@-Z\\-_]|\[[0-?]*[ -/]*[@-~])')
                for line in output_lines:
                    f.write(ansi_escape.sub('', line) + '\n')
            print("-" * 60)
            print(f"{Colors.GREEN}[SUCCESS]{Colors.ENDC} Results saved to '{args.output}'")
        except IOError as e:
            print(f"{Colors.RED}[ERROR]{Colors.ENDC} Could not save to file: {e}")

if __name__ == "__main__":
    main()
