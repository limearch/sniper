#!/usr/bin/python

# sniper-text-image.py (Final Version with Rich Help)
import sys
import argparse

try:
    from PIL import Image
except ImportError:
    print("\n\033[91m[ERROR]\033[0m The 'Pillow' library is not installed.")
    print("Please install it to use this tool: pip install Pillow\n")
    sys.exit(1)

# --- NEW: Rich dependency for help screen ---
try:
    from rich.console import Console
    from rich.panel import Panel
    from rich.text import Text
    rich_available = True
except ImportError:
    rich_available = False

# --- Shared Utilities (Original) ---
# Kept for the main application's colored output
class Colors:
    BLUE = '\033[94m'
    GREEN = '\033[92m'
    RED = '\033[91m'
    YELLOW = '\033[93m'
    CYAN = '\033[96m'
    MAGENTA = '\033[95m'
    ENDC = '\033[0m'
    BOLD = '\033[1m'

def print_info(message): print(f"{Colors.BLUE}[INFO]{Colors.ENDC} {message}")
def print_success(message): print(f"{Colors.GREEN}[SUCCESS]{Colors.ENDC} {message}")
def print_error(message): print(f"{Colors.RED}[ERROR]{Colors.ENDC} {message}", file=sys.stderr)

# --- Core Logic (All original functions are unchanged) ---
CHARSETS = {
    "standard": "@%#*+=-:. ",
    "detailed": "$@B%8&WM#*oahkbdpqwmZO0QLCJUYXzcvunxrjft/\\|()1{}[]?-_+~<>i!lI;:,\"^`'. ",
    "blocks": "█▓▒░ "
}

def resize_image(image, new_width=100):
    width, height = image.size
    aspect_ratio = height / width
    new_height = int(aspect_ratio * new_width * 0.55)
    resized_image = image.resize((new_width, new_height), Image.Resampling.LANCZOS)
    return resized_image, new_height

def image_to_ascii(image, charset_key, invert, use_color):
    charset = CHARSETS[charset_key]
    char_ramp = charset[::-1] if invert else charset
    if use_color:
        return color_image_to_ascii(image, char_ramp)
    else:
        grayscale_image = image.convert("L")
        return grayscale_image_to_ascii(grayscale_image, char_ramp)

def grayscale_image_to_ascii(image, char_ramp):
    pixels = image.getdata()
    return "".join([char_ramp[int((p / 255) * (len(char_ramp) - 1))] for p in pixels])

def color_image_to_ascii(image, char_ramp):
    grayscale_image = image.convert("L")
    grayscale_pixels = grayscale_image.getdata()
    color_pixels = image.getdata()
    color_ascii_str = []
    for i, p in enumerate(grayscale_pixels):
        char = char_ramp[int((p / 255) * (len(char_ramp) - 1))]
        r, g, b = color_pixels[i]
        color_code = f"\033[38;2;{r};{g};{b}m"
        color_ascii_str.append(color_code + char)
    return "".join(color_ascii_str) + Colors.ENDC

def format_ascii_string(ascii_str, width, is_color):
    if is_color:
        output = ""
        char_count = 0
        i = 0
        while i < len(ascii_str):
            if ascii_str[i] == '\033':
                m_pos = ascii_str.find('m', i)
                if m_pos != -1:
                    output += ascii_str[i:m_pos+1]
                    i = m_pos + 1
                else:
                    i += 1
            else:
                output += ascii_str[i]
                char_count += 1
                if char_count % width == 0:
                    output += "\n"
                i += 1
        return output
    else:
        return "\n".join([ascii_str[i:i + width] for i in range(0, len(ascii_str), width)])

# --- NEW: Rich Help Screen Function ---
def show_rich_help():
    """Displays the custom, rich-formatted help screen for text-image."""
    if not rich_available:
        print("Error: 'rich' library is required for the help screen. Run: pip install rich")
        sys.exit(1)
        
    console = Console()
    title = Text("SNIPER: Text-Image Converter", style="bold magenta", justify="center")
    
    usage = Text.from_markup(
        "[bold]Usage:[/] [yellow]text-image[/] [cyan]<IMAGE_PATH>[/] [green][OPTIONS][/]"
    )
    
    options_text = """
[bold]Arguments:[/b]
  [cyan]<IMAGE_PATH>[/]       Path to the input image file.

[bold]Options:[/b]
  [green]-w, --width[/]        Width of the output in characters (default: 100).
  [green]-c, --color[/]        Generate 24-bit colored ASCII art.
  [green]-i, --invert[/]       Invert character ramp, useful for light backgrounds.
  [green]--charset[/]       Character set to use (default: standard).
                         Choices: [cyan]standard, detailed, blocks[/]
  [green]-o, --output <FILE>[/] Path to save the output text file.
  [green]-h, --help[/]         Show this help message and exit.
"""

    examples_text = """
[bold]Examples:[/b]
  [#] Simple conversion of a local image
  [yellow]text-image[/] [cyan]photo.jpg[/]

  [#] Generate detailed, colored art and save it
  [yellow]text-image[/] [cyan]logo.png[/] [green]-w 150 --charset detailed -c -o art.txt[/]
  
  [#] Use block characters for a mosaic effect
  [yellow]text-image[/] [cyan]profile.png[/] [green]--charset blocks -i[/]
"""

    dependencies_text = """
[bold]Dependencies:[/b]
  - [cyan]Pillow[/]: The core image processing library.
    ([yellow]pip install Pillow[/])
  - [cyan]rich[/]: Required for this help screen.
    ([yellow]pip install rich[/])
"""

    errors_text = """
[bold]Common Errors & Tips:[/b]
  - [red]"Could not open or process the image"[/]: Make sure the file path is correct
    and the file is a valid, uncorrupted image (e.g., JPG, PNG).
  - The [green]--color[/] option requires a terminal that supports True Color. Most
    modern terminals (like Windows Terminal, GNOME Terminal, iTerm2) do.
  - If the output looks stretched, your terminal font might not be monospace.
"""
    
    console.print(Panel(title, border_style="magenta", padding=(0, 1)))
    console.print(usage, justify="center")
    console.print(Panel(Text.from_markup(options_text.strip()), title="Options", border_style="blue"))
    console.print(Panel(Text.from_markup(examples_text.strip()), title="Examples", border_style="green"))
    console.print(Panel(Text.from_markup(dependencies_text.strip()), title="Dependencies", border_style="cyan"))
    console.print(Panel(Text.from_markup(errors_text.strip()), title="Troubleshooting", border_style="yellow"))
    sys.exit(0)

# --- Main Execution ---
def main():
    # --- MODIFIED: Argument Parser Setup ---
    parser = argparse.ArgumentParser(
        prog="sniper-text-image",
        description="A tool to convert images into ASCII art.",
        add_help=False # Disable default help
    )
    
    # --- NEW: Manual help argument ---
    parser.add_argument("-h", "--help", action="store_true", help="Show this help message and exit.")

    # --- Original Arguments (Unchanged, but image_path is now optional) ---
    parser.add_argument("image_path", nargs='?', default=None, metavar="<IMAGE_PATH>", help="Path to the input image file.")
    parser.add_argument("-w", "--width", type=int, default=100, help="Width of the output in characters. (Default: 100)")
    parser.add_argument("-o", "--output", metavar="<FILE>", help="Path to save the output text file.")
    parser.add_argument("-i", "--invert", action="store_true", help="Invert character ramp for light backgrounds.")
    parser.add_argument("-c", "--color", action="store_true", help="Generate 24-bit colored ASCII art.")
    parser.add_argument("--charset", choices=CHARSETS.keys(), default="standard", help="Character set to use. (Default: standard)")

    args = parser.parse_args()

    # --- NEW: Help screen trigger ---
    if args.help or not args.image_path:
        show_rich_help()

    # --- Original Core Execution (Unchanged) ---
    try:
        print_info(f"Opening image: {args.image_path}")
        image = Image.open(args.image_path)
    except FileNotFoundError:
        print_error(f"The file '{args.image_path}' was not found.")
        sys.exit(1)
    except Exception as e:
        print_error(f"Could not open or process the image: {e}")
        sys.exit(1)
    print_info("Resizing and converting image...")
    if args.color:
        image = image.convert("RGB")
    resized_image, _ = resize_image(image, args.width)
    raw_ascii_string = image_to_ascii(resized_image, args.charset, args.invert, args.color)
    formatted_art = format_ascii_string(raw_ascii_string, resized_image.width, args.color)
    if args.output:
        print_info(f"Saving output to {args.output}...")
        try:
            with open(args.output, "w", encoding="utf-8") as f:
                f.write(formatted_art)
            print_success(f"ASCII art saved successfully to '{args.output}'")
        except IOError as e:
            print_error(f"Could not save to file: {e}")
            sys.exit(1)
    else:
        print(f"\n{formatted_art}\n")

if __name__ == "__main__":
    main()
