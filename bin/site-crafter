#!/usr/bin/env python3
import sys
import argparse
import requests
import os
import subprocess
from pathlib import Path
from urllib.parse import urljoin, urlparse

# --- Dependency Checks ---
try:
    from rich.console import Console
    from rich.panel import Panel
    from rich.text import Text
    from rich.progress import Progress, BarColumn, TextColumn, TimeElapsedColumn
    from rich.prompt import Confirm
    from rich.rule import Rule
except ImportError:
    print("Error: The 'rich' library is required. Please run: pip install rich")
    sys.exit(1)

try:
    from bs4 import BeautifulSoup
except ImportError:
    print("Error: The 'beautifulsoup4' library is required. Please run: pip install beautifulsoup4")
    sys.exit(1)

try:
    import validators
except ImportError:
    print("Error: The 'validators' library is required. Please run: pip install validators")
    sys.exit(1)

# --- Global Console & Constants ---
console = Console()
FLASK_TEMPLATE = """
from flask import Flask, render_template, send_from_directory
import os

app = Flask(__name__)

# This route serves files from the 'static' directory
@app.route('/static/<path:filename>')
def static_files(filename):
    return send_from_directory(os.path.join(app.root_path, 'static'), filename)

@app.route('/')
def index():
    return render_template('index.html')

if __name__ == '__main__':
    # Running on 0.0.0.0 makes it accessible on your local network
    app.run(debug=True, host='0.0.0.0', port=5000)
"""

# --- Rich Help Screen ---
def show_rich_help():
    title = Text("SNIPER: site-crafter - Web to Flask Project Converter", style="bold magenta", justify="center")
    
    usage = Text.from_markup("[bold]Usage:[/] [yellow]site-crafter[/] [cyan]<URL>[/] [green]-p <PROJECT_NAME>[/] [cyan][OPTIONS][/]")
    
    main_panel_text = """
[bold]Description:[/b]
  A powerful tool that downloads a live website and automatically converts
  it into a fully functional, local Flask project. It handles HTML, CSS,
  JavaScript, images, and sets up a ready-to-run environment.

[bold]Required Arguments:[/b]
  [cyan]<URL>[/]                  The full URL of the website to clone.
  [green]-p, --project <NAME>[/]  The name for the new project directory.
"""
    options_text = """
[bold]Options:[/b]
  [green]-h, --help[/]             Show this help message and exit.
  [green]--no-venv[/]             Skip the creation of a Python virtual environment.
  [green]--run[/]                 Attempt to run the Flask server after creation.
"""
    examples_text = """
[bold]Examples:[/b]
  [#] Create a project named 'my-site' from a URL
  [yellow]site-crafter[/] [cyan]https://example.com[/] [green]-p my-site[/]

  [#] Create a project and immediately run the local server
  [yellow]site-crafter[/] [cyan]https://getbootstrap.com/docs/5.0/examples/starter-template/[/] [green]-p bootstrap-site --run[/]
"""
    
    console.print(Panel(title, border_style="magenta", padding=(0, 1)))
    console.print(usage, justify="center")
    console.print(Panel(Text.from_markup(main_panel_text.strip()), title="Overview", border_style="blue"))
    console.print(Panel(Text.from_markup(options_text.strip()), title="Options", border_style="cyan"))
    console.print(Panel(Text.from_markup(examples_text.strip()), title="Examples", border_style="green"))
    sys.exit(0)

# --- Core Logic Functions ---

def create_project_structure(project_dir):
    """Creates the necessary Flask directories."""
    console.print(Rule("[bold cyan]Step 1: Creating Project Structure[/]"))
    try:
        (project_dir / "templates").mkdir(parents=True, exist_ok=True)
        (project_dir / "static").mkdir(exist_ok=True)
        console.print(f"  [green]✔[/] Created directories: [cyan]templates/[/] and [cyan]static/[/]")

        main_py_path = project_dir / "app.py"
        with open(main_py_path, "w", encoding="utf-8") as f:
            f.write(FLASK_TEMPLATE)
        console.print(f"  [green]✔[/] Created Flask server file: [cyan]app.py[/]")
    except OSError as e:
        console.print(f"[bold red]Error:[/] Could not create project directories: {e}")
        return False
    return True

def download_and_process(url, project_dir):
    """Downloads the site, its assets, and rewrites paths."""
    console.print(Rule("[bold cyan]Step 2: Downloading Website Content[/]"))
    
    session = requests.Session()
    session.headers.update({'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'})

    try:
        response = session.get(url)
        response.raise_for_status()
    except requests.RequestException as e:
        console.print(f"[bold red]Error:[/] Failed to fetch URL '{url}': {e}")
        return False

    soup = BeautifulSoup(response.content, 'html.parser')
    
    tags = {'link': 'href', 'script': 'src', 'img': 'src', 'video': 'src', 'source': 'src'}
    resources_to_download = []

    for tag, attr in tags.items():
        for res in soup.find_all(tag):
            if res.has_attr(attr):
                res_url = res[attr]
                if not res_url or res_url.startswith(('data:', '#')):
                    continue
                
                abs_url = urljoin(url, res_url)
                if urlparse(abs_url).netloc != urlparse(url).netloc:
                    continue

                file_name = Path(urlparse(res_url).path).name
                if not file_name: continue
                
                local_path = project_dir / "static" / file_name
                if (abs_url, local_path) not in resources_to_download:
                    resources_to_download.append((abs_url, local_path))
                
                res[attr] = f"{{{{ url_for('static', filename='{file_name}') }}}}"

    with Progress(TextColumn("[progress.description]{task.description}"), BarColumn(), "[progress.percentage]{task.percentage:>3.1f}%", TimeElapsedColumn(), console=console) as progress:
        task = progress.add_task("Downloading assets...", total=len(resources_to_download))
        for res_url, local_path in resources_to_download:
            try:
                res_response = session.get(res_url, stream=True)
                res_response.raise_for_status()
                with open(local_path, 'wb') as f:
                    for chunk in res_response.iter_content(chunk_size=8192):
                        f.write(chunk)
                progress.update(task, advance=1, description=f"Downloading [green]{local_path.name}[/]")
            except requests.RequestException:
                progress.update(task, advance=1, description=f"Skipping [red]{local_path.name}[/]")

    index_html_path = project_dir / "templates" / "index.html"
    with open(index_html_path, 'w', encoding='utf-8') as f:
        f.write(str(soup.prettify()))
    console.print(f"  [green]✔[/] Processed and saved [cyan]index.html[/]")
    return True

def setup_environment(project_dir):
    """Creates a virtual environment and installs Flask."""
    console.print(Rule("[bold cyan]Step 3: Setting Up Environment[/]"))
    
    venv_path = project_dir / "venv"
    console.print(f"Creating virtual environment in [cyan]{venv_path}[/]")
    
    try:
        subprocess.run([sys.executable, "-m", "venv", str(venv_path)], check=True, capture_output=True, text=True)
        console.print("  [green]✔[/] Virtual environment created.")
    except subprocess.CalledProcessError as e:
        console.print(f"[bold red]Error:[/] Failed to create virtual environment: {e.stderr}")
        return False
        
    pip_executable = str(venv_path / "bin" / "pip") if os.name != "nt" else str(venv_path / "Scripts" / "pip.exe")

    console.print("Installing Flask...")
    try:
        subprocess.run([pip_executable, "install", "flask"], check=True, capture_output=True, text=True)
        console.print("  [green]✔[/] Flask installed successfully.")
        return True
    except subprocess.CalledProcessError as e:
        console.print(f"[bold red]Error:[/] Failed to install Flask: {e.stderr}")
        return False

def run_server(project_dir, no_venv_mode):
    """Runs the newly created Flask server, handling both venv and no-venv modes."""
    console.print(Rule("[bold cyan]Step 4: Running Server[/]"))

    project_path_abs = project_dir.resolve()
    app_path = project_path_abs / "app.py"
    
    python_executable = ""
    
    if no_venv_mode:
        python_executable = sys.executable
        console.print("[yellow]Running server using the global Python interpreter...[/]")
    else:
        venv_python_path = project_path_abs / "venv" / "bin" / "python" if os.name != "nt" else project_path_abs / "venv" / "Scripts" / "python.exe"
        if not venv_python_path.exists():
            console.print(f"[bold red]Error:[/] Virtual environment Python not found at '{venv_python_path}'.")
            return
        python_executable = str(venv_python_path)

    if not app_path.exists():
        console.print("[bold red]Error:[/] Cannot run server. 'app.py' is missing.")
        return
        
    console.print(f"Server is starting at http://0.0.0.0:5000", style="yellow")
    console.print("Press [bold]Ctrl+C[/] to stop.", style="yellow")
    
    try:
        command_to_run = [python_executable, str(app_path)]
        subprocess.run(command_to_run, cwd=str(project_path_abs))
    except KeyboardInterrupt:
        console.print("\nServer stopped.")
    except Exception as e:
        console.print(f"[bold red]Failed to run server: {e}[/]")

def main():
    parser = argparse.ArgumentParser(prog="site-crafter", add_help=False)
    parser.add_argument("url", nargs='?', default=None, help="The URL of the website to clone.")
    parser.add_argument("-p", "--project", default=None, help="The name for the new project directory.")
    parser.add_argument("-h", "--help", action="store_true", help="Show this help message.")
    parser.add_argument("--no-venv", action="store_true", help="Skip creating a virtual environment.")
    parser.add_argument("--run", action="store_true", help="Run the Flask server after creation.")
    
    args = parser.parse_args()

    if args.help:
        show_rich_help()

    if not args.url or not args.project:
        if not args.help:
            console.print("[bold red]Error:[/] Both a URL and a project name (-p) are required.\n")
        show_rich_help()
    
    if not validators.url(args.url):
        console.print(f"[bold red]Error:[/] Invalid URL provided: '{args.url}'")
        sys.exit(1)
        
    project_dir = Path(args.project)
    if project_dir.exists():
        if not Confirm.ask(f"[bold yellow]Warning:[/] Directory '{project_dir}' already exists. Overwrite?"):
            console.print("Operation cancelled.")
            sys.exit(0)

    # --- Main Workflow ---
    if not create_project_structure(project_dir): sys.exit(1)
    if not download_and_process(args.url, project_dir): sys.exit(1)
    
    if not args.no_venv:
        if not setup_environment(project_dir): sys.exit(1)
            
    if args.run:
        run_server(project_dir, args.no_venv)
    else:
        console.print(Rule("[bold green]Project Created Successfully![/]", style="green"))
        if not args.no_venv:
            activate_cmd = f"source {project_dir.resolve() / 'venv' / 'bin' / 'activate'}" if os.name != "nt" else f"{project_dir.resolve() / 'venv' / 'Scripts' / 'activate'}"
            console.print("To run your new server, use the following commands:")
            console.print(f"  1. [cyan]cd {args.project}[/]")
            console.print(f"  2. [cyan]{activate_cmd}[/]")
            console.print(f"  3. [cyan]python app.py[/]")
        else:
             console.print("To run your new server, use the following commands:")
             console.print(f"  1. [cyan]cd {args.project}[/]")
             console.print(f"  2. [cyan]pip install flask[/]")
             console.print(f"  3. [cyan]python app.py[/]")

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        console.print("\n[yellow]Operation cancelled by user.[/]")
