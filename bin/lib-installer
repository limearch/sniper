#!/usr/bin/env python3
import sys
import argparse
import requests
import subprocess
import json
from pathlib import Path

# --- Dependency Check for Rich ---
try:
    from rich.console import Console
    from rich.panel import Panel
    from rich.text import Text
    from rich.table import Table
    from rich.progress import Progress
    from rich.markdown import Markdown
    from rich.rule import Rule
    from rich.prompt import Prompt, Confirm
except ImportError:
    print("Error: The 'rich' library is required. Please run: pip install rich")
    sys.exit(1)

# --- Global Console Object ---
console = Console()

# --- NEW: Rich Help Screen Function ---
def show_rich_help():
    title = Text("SNIPER: lib-installer - Advanced Python Package Manager", style="bold magenta", justify="center")
    
    usage = Text.from_markup(
        "[bold]Usage:[/] [yellow]lib-installer[/] [cyan]<COMMAND>[/] [green][ARGUMENTS][/]"
    )
    
    main_panel_text = """
[bold]Description:[/b]
  A powerful and user-friendly wrapper around 'pip' to search, install,
  and manage Python packages from PyPI with an enhanced interface.
"""

    commands_text = """
[bold]Available Commands:[/b]
  [green]search <package>[/]   Search for a package on PyPI.
  [green]install <package>[/]  Install a package. Optionally specify a version (e.g., [cyan]requests==2.25.1[/]).
  [green]uninstall <package>[/] Uninstall a package.
  [green]info <package>[/]     Show detailed information about a package.
  [green]list[/]                List all installed packages.
  [green]list-outdated[/]       List all outdated packages.
  [green]update <package>[/]   Update a specific package to the latest version.
  [green]update-all[/]          Update all outdated packages.
  [green]req-install[/]         Install packages from a 'requirements.txt' file.
  [green]req-export[/]          Export installed packages to 'requirements.txt'.
  [green]help[/]                Show this help message.
"""

    examples_text = """
[bold]Examples:[/b]
  [#] Search for the 'requests' library
  [yellow]lib-installer[/] [green]search[/] [cyan]requests[/]

  [#] Install a specific version of a package
  [yellow]lib-installer[/] [green]install[/] [cyan]"django<4.0"[/]

  [#] Show detailed information about 'rich'
  [yellow]lib-installer[/] [green]info[/] [cyan]rich[/]

  [#] Update all outdated packages
  [yellow]lib-installer[/] [green]update-all[/]
"""
    
    console.print(Panel(title, border_style="magenta", padding=(0, 1)))
    console.print(usage, justify="center")
    console.print(Panel(Text.from_markup(main_panel_text.strip()), title="Overview", border_style="blue"))
    console.print(Panel(Text.from_markup(commands_text.strip()), title="Commands", border_style="cyan"))
    console.print(Panel(Text.from_markup(examples_text.strip()), title="Examples", border_style="green"))
    sys.exit(0)

# --- Secure Subprocess Execution ---
def run_pip_command(command, show_output=True):
    """Executes a pip command securely and returns the exit code."""
    try:
        # Use a list of arguments for better security and parsing
        full_command = [sys.executable, "-m", "pip"] + command
        
        if show_output:
            # Stream output directly to the console
            process = subprocess.run(full_command, check=True)
            return process.returncode
        else:
            # Run silently and capture output
            result = subprocess.run(full_command, capture_output=True, text=True, check=False)
            if result.returncode != 0:
                console.print(f"[bold red]Pip Error:[/] {result.stderr.strip()}")
            return result.returncode, result.stdout
            
    except subprocess.CalledProcessError as e:
        # Errors are already printed by subprocess if show_output is True
        return e.returncode
    except FileNotFoundError:
        console.print("[bold red]Error:[/] 'pip' command not found. Is Python installed correctly?[/]")
        return 1

# --- Command Implementations ---

def search_package(package_name):
    console.print(f"[cyan]Searching for '[bold]{package_name}[/]' on PyPI...[/]")
    try:
        response = requests.get(f"https://pypi.org/search/?q={package_name}")
        response.raise_for_status()
        
        # This is a simple search, can be expanded with BeautifulSoup if needed
        # For now, we will use pip's own search for reliability.
        console.print(f"--- Results from 'pip search {package_name}' ---")
        run_pip_command(["search", package_name])
    except requests.RequestException as e:
        console.print(f"[bold red]Network error during search: {e}[/]")

def get_package_info(package_name):
    console.print(f"[cyan]Fetching details for '[bold]{package_name}[/]'...[/]")
    try:
        response = requests.get(f"https://pypi.org/pypi/{package_name}/json")
        response.raise_for_status()
        data = response.json()
        info = data.get("info", {})

        table = Table(title=f"Details for {info.get('name', package_name)}", show_header=False, box=None, expand=True)
        table.add_column("Property", style="bold magenta", width=20)
        table.add_column("Value", style="green")

        table.add_row("Version", info.get("version", "N/A"))
        table.add_row("Author", info.get("author", "N/A"))
        table.add_row("License", info.get("license", "N/A"))
        table.add_row("Homepage", info.get("home_page", "N/A"))
        table.add_row("PyPI URL", info.get("package_url", "N/A"))
        
        console.print(table)
        console.print(Rule("Summary"))
        console.print(Markdown(info.get("summary", "No summary available.")))
        
    except requests.HTTPError as e:
        if e.response.status_code == 404:
            console.print(f"[bold red]Error:[/] Package '{package_name}' not found on PyPI.")
        else:
            console.print(f"[bold red]HTTP error: {e}[/]")
    except requests.RequestException as e:
        console.print(f"[bold red]Network error: {e}[/]")

def update_all_packages():
    console.print("[cyan]Checking for outdated packages...[/]")
    _, output = run_pip_command(["list", "--outdated", "--format=json"], show_output=False)
    
    try:
        outdated = json.loads(output)
    except json.JSONDecodeError:
        console.print("[bold red]Could not parse list of outdated packages.[/]")
        return

    if not outdated:
        console.print("[bold green]All packages are up to date![/]")
        return
        
    console.print(f"Found [bold yellow]{len(outdated)}[/] outdated package(s).")
    if Confirm.ask("Do you want to update them all?"):
        packages_to_update = [pkg['name'] for pkg in outdated]
        with Progress() as progress:
            task = progress.add_task("[green]Updating...", total=len(packages_to_update))
            for pkg_name in packages_to_update:
                progress.update(task, description=f"Updating {pkg_name}...")
                run_pip_command(["install", "--upgrade", pkg_name], show_output=False)
                progress.advance(task)
        console.print("[bold green]All packages updated successfully.[/]")


# --- Main CLI Router ---
def main():
    parser = argparse.ArgumentParser(prog="lib-installer", add_help=False)
    subparsers = parser.add_subparsers(dest="command", help="Available commands")

    # Define subparsers for each command
    subparsers.add_parser("search").add_argument("package")
    subparsers.add_parser("install").add_argument("package", nargs='+')
    subparsers.add_parser("uninstall").add_argument("package")
    subparsers.add_parser("info").add_argument("package")
    subparsers.add_parser("list")
    subparsers.add_parser("list-outdated")
    subparsers.add_parser("update").add_argument("package")
    subparsers.add_parser("update-all")
    subparsers.add_parser("req-install")
    subparsers.add_parser("req-export")
    subparsers.add_parser("help")

    args, remaining_args = parser.parse_known_args()

    # --- Command Dispatcher ---
    if args.command == "help" or not args.command:
        show_rich_help()
    elif args.command == "search":
        search_package(args.package)
    elif args.command == "install":
        run_pip_command(["install"] + args.package)
    elif args.command == "uninstall":
        if Confirm.ask(f"Are you sure you want to uninstall '{args.package}'?"):
            run_pip_command(["uninstall", "-y", args.package])
    elif args.command == "info":
        get_package_info(args.package)
    elif args.command == "list":
        run_pip_command(["list"])
    elif args.command == "list-outdated":
        run_pip_command(["list", "--outdated"])
    elif args.command == "update":
        run_pip_command(["install", "--upgrade", args.package])
    elif args.command == "update-all":
        update_all_packages()
    elif args.command == "req-install":
        req_file = "requirements.txt"
        if not Path(req_file).is_file():
            console.print(f"[bold red]Error:[/] '{req_file}' not found.")
        else:
            run_pip_command(["install", "-r", req_file])
    elif args.command == "req-export":
        req_file = "requirements.txt"
        console.print(f"[cyan]Exporting installed packages to '{req_file}'...[/]")
        return_code, output = run_pip_command(["freeze"], show_output=False)
        if return_code == 0:
            try:
                with open(req_file, 'w') as f:
                    f.write(output)
                console.print(f"[bold green]Successfully exported to '{req_file}'.[/]")
            except IOError as e:
                console.print(f"[bold red]Error writing to file: {e}[/]")
    else:
        console.print(f"[bold red]Unknown command: '{args.command}'[/]")
        show_rich_help()

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        console.print("\n[yellow]Operation cancelled by user.[/]")


